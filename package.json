{
  "name": "@tinyland-inc/tinyland-physics",
  "version": "0.1.0",
  "description": "Physics simulation engines for blob animations, scroll handling, and device motion",
  "type": "module",
  "license": "(Zlib AND LicenseRef-Tinyland-Proprietary)",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./types": {
      "import": "./src/types.ts",
      "types": "./src/types.ts"
    },
    "./schema": {
      "import": "./src/schema.ts",
      "types": "./src/schema.ts"
    }
  },
  "files": [
    "src/",
    "!src/**/*.test.ts"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "physics",
    "animation",
    "blob",
    "wasm",
    "scroll",
    "device-motion"
  ],
  "author": "Tinyland Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/tinyland-inc/tinyland-physics.git"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^4.0.0",
    "jsdom": "^25.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  }
}
